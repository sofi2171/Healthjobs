{
  "appId": "com.sufian.healthjobs",
  "appName": "Healthjobs",
  "webDir": "www",
  "plugins": {
    "StatusBar": {
      "overlaysWebView": true
    },
    "GoogleAuth": {
      "scopes": [
        "profile",
        "email"
      ],
      "serverClientId": "21065686301-145no417sg9qudgkt619foccih0hnt11.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    },
    "CapacitorHttp": {
      "enabled": false
    },
    "SplashScreen": {
      "launchShowDuration": 3000,
      "backgroundColor": "#ffffff",
      "androidScaleType": "FIT_CENTER",
      "showSpinner": true,
      "androidSpinnerStyle": "large",
      "spinnerColor": "#999999",
      "splashFullScreen": false,
      "splashImmersive": false
    }
  }
}