{
  "appId": "com.sufian.healthjobs",
  "appName": "Healthjobs",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "healthjobportal.com",
      "healthjobs-portal.web.app"
    ]
  },
  "plugins": {
    "App": {
      "launchUrl": "https://healthjobportal.com"
    },
    "SocialLogin": {
      "google": {
        "webClientId": "21065686301-145no417sg9qudgkt619foccih0hnt11.apps.googleusercontent.com"
      }
    },
    "SplashScreen": {
      "launchShowDuration": 0,
      "backgroundColor": "#ffffff"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_notification",
      "iconColor": "#0a66c2"
    },
    "Keyboard": {
      "resize": "ionic",
      "style": "DARK",
      "resizeOnFullScreen": true
    }
  }
}
